# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas — get from atlas.mongodb.com (free M0 tier)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/cleancruisers?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRE=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Green API — FREE WhatsApp (green-api.com)
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token

# Frontend URL — your Vercel URL (comma-separate multiple)
FRONTEND_URL=https://your-app.vercel.app,http://localhost:5173

# Render keep-alive — set automatically by Render, don't change
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Admin seed credentials
ADMIN_EMAIL=admin@cleancruisers.com
ADMIN_PASSWORD=YourStrongPassword123!
